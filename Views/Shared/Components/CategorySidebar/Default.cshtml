@model IEnumerable<Lab5.Models.Category>

<div class="d-flex flex-column gap-1">
    <!-- All products link -->
    <a asp-controller="Book" asp-action="Index" 
       class="sidebar-link @(Context.Request.Query["categoryId"].ToString() == "" ? "active" : "")">
        <span><i class="bi bi-collection-fill me-2"></i>Tất cả sách</span>
        <span class="category-count-badge">ALL</span>
    </a>

    <!-- Category dynamic links -->
    @foreach (var cat in Model)
    {
        var isActive = Context.Request.Query["categoryId"].ToString() == cat.CategoryId.ToString();
        <a asp-controller="Book" asp-action="Index" asp-route-categoryId="@cat.CategoryId" 
           class="sidebar-link @(isActive ? "active" : "")">
            <span><i class="bi bi-bookmark-star-fill me-2 text-warning"></i>@cat.CategoryName</span>
            <span class="category-count-badge">@(cat.Books?.Count ?? 0)</span>
        </a>
    }
</div>
