<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cửa hàng sách Premium</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <div class="main-container shadow-lg my-4">
        <!-- Premium Modern Header -->
        <header>
            <nav class="navbar navbar-expand-md navbar-dark navbar-premium">
                <div class="container-fluid px-2">
                    <a class="navbar-brand navbar-brand-premium fw-extrabold" asp-area="" asp-controller="Book" asp-action="Index">
                        <i class="bi bi-book-half"></i> BOOKSTORE
                    </a>
                    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-white-50 px-3" asp-area="" asp-controller="Book" asp-action="Index">
                                    <i class="bi bi-shop me-1"></i> Cửa hàng sách
                                </a>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-danger fw-bold px-3" href="#" id="navbarDropdownAdmin" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-shield-lock me-1"></i> Quản trị Admin
                                    </a>
                                    <ul class="dropdown-menu border-0 shadow-lg mt-2" aria-labelledby="navbarDropdownAdmin" style="border-radius: 12px;">
                                        <li>
                                            <a class="dropdown-item py-2 px-3 fw-semibold text-dark" asp-area="Admin" asp-controller="User" asp-action="Index">
                                                <i class="bi bi-people me-2"></i> Quản lý thành viên
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }
                        </ul>
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </nav>
        </header>
        
        <!-- Main Shop Layout Split -->
        <div class="container-fluid px-4 py-5">
            <div class="row g-4">
                <!-- Left Category Sidebar -->
                <div class="col-lg-3">
                    <div class="sidebar-premium-card">
                        <div class="sidebar-title">
                            <i class="bi bi-grid-fill text-primary"></i> Danh mục sách
                        </div>
                        @await Component.InvokeAsync("CategorySidebar")
                    </div>
                </div>
                
                <!-- Right Public/Admin Content Area -->
                <div class="col-lg-9">
                    @RenderBody()
                </div>
            </div>
        </div>

        <!-- Premium Footer -->
        <footer class="footer text-center py-4 border-top bg-light-subtle text-muted small">
            &copy; 2026 - Bookstore Premium - Nâng tầm trải nghiệm đọc sách 📚
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
