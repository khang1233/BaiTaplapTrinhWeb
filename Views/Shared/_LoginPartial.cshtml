@using Microsoft.AspNetCore.Identity
@using Lab5.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center">
@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    var fullName = user?.FullName ?? User.Identity?.Name;
    var isAdmin = User.IsInRole("Admin");

    <li class="nav-item">
        <span class="nav-link text-dark pe-3">
            Xin chào, 
            @if (isAdmin)
            {
                <span class="badge bg-danger text-white fw-bold me-1">Admin</span>
            }
            else
            {
                <span class="badge bg-primary text-white fw-bold me-1">Member</span>
            }
            <strong class="text-dark">@fullName</strong>!
        </span>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="nav-link btn btn-link text-danger fw-semibold border-0 py-0">Đăng xuất</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark fw-medium px-3" asp-area="Identity" asp-page="/Account/Register">Đăng ký</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark fw-medium px-3 btn btn-outline-primary btn-sm rounded-pill py-1 text-primary-hover" asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a>
    </li>
}
</ul>
