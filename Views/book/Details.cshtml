@model Lab5.Models.Book
@{
    ViewData["Title"] = "Chi Tiết Sách - " + Model.Title;
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3 shadow-sm text-decoration-none">
        <i class="bi bi-arrow-left-circle me-1"></i> Quay trở lại danh mục sách
    </a>
</div>

<div class="detail-card-premium">
    <div class="row g-5 align-items-center">
        <!-- Book Left Column (Image) -->
        <div class="col-md-5">
            <div class="detail-img-container">
                <img src="/ImageBooks/@Model.ImageUrl" class="detail-img img-fluid rounded-3" alt="@Model.Title" style="max-height: 400px; object-fit: contain;">
            </div>
        </div>
        
        <!-- Book Right Column (Content) -->
        <div class="col-md-7">
            <!-- Breadcrumb Category -->
            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill mb-3 fw-bold uppercase tracking-wider">
                <i class="bi bi-tags-fill me-1"></i>@(Model.Category?.CategoryName ?? "Sách chọn lọc")
            </span>
            
            <h1 class="fw-extrabold text-dark mb-3 lh-base fs-3">@Model.Title</h1>
            
            <div class="row border-bottom pb-3 mb-4 text-muted small">
                <div class="col-6 d-flex align-items-center gap-1">
                    <i class="bi bi-pencil-square text-primary"></i> Tác giả: <strong class="text-dark">@Model.Author</strong>
                </div>
                <div class="col-6 text-end d-flex align-items-center justify-content-end gap-1">
                    <i class="bi bi-building text-info"></i> Nhà XB: <strong class="text-dark">NXB Trẻ</strong>
                </div>
            </div>

            <!-- Review Stars -->
            <div class="mb-4 text-warning fs-5">
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
                <i class="bi bi-star-fill"></i>
                <span class="text-muted small fs-6 ms-2">(124 đánh giá chính hãng)</span>
            </div>

            <!-- Price Box -->
            <div class="p-3 bg-light rounded-3 mb-4 d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted small d-block mb-1 text-decoration-line-through">Giá gốc: @String.Format("{0:#,##0} đ", Model.Price * 1300)</span>
                    <span class="text-danger fs-3 fw-extrabold">@String.Format("{0:#,##0} đ", Model.Price * 1000)</span>
                </div>
                <span class="badge bg-danger rounded-pill px-3 py-2 fs-6">-23% GIẢM</span>
            </div>

            <!-- Shipping Policy Box -->
            <div class="card bg-light border-0 rounded-3 p-3 mb-4 small">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="text-muted"><i class="bi bi-truck me-2 text-primary"></i>Giao hàng tận nơi</span>
                    <span class="fw-semibold text-dark">Miễn phí toàn quốc</span>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                    <span class="text-muted"><i class="bi bi-shield-check me-2 text-success"></i>Chính sách bảo mật</span>
                    <span class="fw-semibold text-dark">Đổi trả 100% trong 30 ngày</span>
                </div>
            </div>

            <!-- Buy & Add to Cart -->
            <div class="d-flex align-items-center gap-3">
                <div class="input-group border rounded-pill overflow-hidden" style="width: 140px; height: 48px;">
                    <button class="btn btn-light border-0 px-3 fs-5" type="button" onclick="var i = this.nextElementSibling; if(parseInt(i.value)>1) i.value=parseInt(i.value)-1;">-</button>
                    <input type="text" class="form-control border-0 text-center fw-bold fs-6 bg-white" value="1" readonly>
                    <button class="btn btn-light border-0 px-3 fs-5" type="button" onclick="var i = this.previousElementSibling; i.value=parseInt(i.value)+1;">+</button>
                </div>
                
                <button class="btn btn-outline-danger btn-premium-pill flex-grow-1 py-3 fw-bold" style="height: 48px; border-width: 2px;">
                    <i class="bi bi-cart3 me-1"></i> Giỏ hàng
                </button>
                
                <button class="btn btn-danger btn-premium-pill flex-grow-1 py-3 fw-bold text-white shadow-sm" style="height: 48px;">
                    Mua ngay
                </button>
            </div>
        </div>
    </div>
</div>