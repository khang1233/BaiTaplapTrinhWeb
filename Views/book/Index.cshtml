@model IEnumerable<Lab5.Models.Book>
@{
    ViewData["Title"] = "Cửa hàng sách Premium";
    var activeCategory = Model.FirstOrDefault()?.Category?.CategoryName;
    var hasCategoryId = Context.Request.Query["categoryId"].ToString() != "";
}

<!-- Premium Storefront Hero Banner -->
<div class="p-5 mb-5 text-white rounded-4 shadow-sm position-relative overflow-hidden" 
     style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); min-height: 180px;">
    <div class="position-absolute opacity-10 end-0 bottom-0" style="font-size: 8rem; line-height: 1; transform: translate(10%, 20%); pointer-events: none;">
        <i class="bi bi-book-half"></i>
    </div>
    <div class="position-relative z-1">
        <span class="badge bg-primary px-3 py-2 rounded-pill mb-3 fw-bold tracking-wide">XU HƯỚNG MỚI 2026</span>
        <h1 class="display-6 fw-extrabold tracking-tight text-white mb-2">
            @(hasCategoryId ? $"Danh mục: {activeCategory}" : "Khám phá Thế giới Sách Premium")
        </h1>
        <p class="text-white-50 fs-6 mb-0">Hàng ngàn cuốn sách tuyển chọn bản quyền tinh tuyển chất lượng cao đang chờ đón bạn.</p>
    </div>
</div>

<!-- Header Tools for Admin -->
@if (User.IsInRole("Admin"))
{
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-danger bg-opacity-10 border border-danger border-opacity-20 rounded-3">
        <div class="d-flex align-items-center gap-2 text-danger">
            <i class="bi bi-shield-fill-check fs-5"></i>
            <span class="fw-bold small">CHẾ ĐỘ QUẢN TRỊ VIÊN ACTIVE</span>
        </div>
        <a href="#" class="btn btn-danger btn-sm rounded-pill px-4 fw-semibold shadow-sm">
            <i class="bi bi-plus-circle-fill me-1"></i>Thêm Sách mới
        </a>
    </div>
}

<!-- Grid layout -->
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @if (Model != null && Model.Any())
    {
        foreach (var book in Model)
        {
            <div class="col">
                <div class="book-card-premium">
                    <!-- Image Area -->
                    <div class="book-image-container">
                        <img src="/ImageBooks/@book.ImageUrl" alt="@book.Title" class="book-image-premium img-fluid">
                    </div>
                    
                    <!-- Content Area -->
                    <div class="book-body-premium">
                        <!-- Category Badge -->
                        <span class="book-category-badge">
                            <i class="bi bi-bookmark me-1"></i>@(book.Category?.CategoryName ?? "Chưa rõ")
                        </span>
                        
                        <!-- Book Title -->
                        <h3 class="book-title-premium">
                            <a asp-action="Details" asp-route-id="@book.BookId" class="text-decoration-none text-dark hover-text-primary">
                                @book.Title
                            </a>
                        </h3>
                        
                        <!-- Author -->
                        <div class="book-author">
                            <i class="bi bi-pencil-square me-1"></i>Tác giả: <strong>@book.Author</strong>
                        </div>
                        
                        <!-- Price & Buy Area -->
                        <div class="book-price-row">
                            <div class="d-flex flex-column">
                                <span class="text-muted small text-decoration-line-through mb-0" style="font-size: 11px;">
                                    @String.Format("{0:#,##0}đ", book.Price * 1300)
                                </span>
                                <span class="book-price">
                                    @String.Format("{0:#,##0}đ", book.Price * 1000)
                                </span>
                            </div>
                            
                            <div class="d-flex gap-1 align-items-center">
                                <a asp-action="Details" asp-route-id="@book.BookId" 
                                   class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-bold">
                                    Chi tiết
                                </a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="d-flex gap-1 ms-1">
                                        <a href="#" class="btn btn-outline-warning btn-sm rounded-circle px-2" title="Sửa">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <button class="btn btn-outline-danger btn-sm rounded-circle px-2" title="Xóa">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
            Không tìm thấy cuốn sách nào trong danh mục này.
        </div>
    }
</div>