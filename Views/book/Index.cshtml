@model IEnumerable<Lab5.Models.Book>
@{
    ViewData["Title"] = "Trang Chủ";
}

<div class="mb-3">
    <a href="#" class="text-decoration-none">Thêm mới</a>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
    @foreach (var book in Model)
    {
        <div class="col">
            <div class="card h-100 border-1 shadow-sm">
                <div class="card-header bg-light d-flex justify-content-between align-items-center py-2 px-3 border-bottom">
                    <span class="fs-6 text-dark" style="font-size: 14px;">@book.Title</span>
                    <a href="#" class="text-decoration-none text-primary" style="font-size: 13px;">Edit</a>
                </div>
                <div class="card-body p-3">
                    <p class="card-text mb-1 text-dark" style="font-size: 14px;"><span class="fw-bold">Tác giả:</span> @book.Author</p>
                    <p class="card-text mb-3 text-dark" style="font-size: 14px;"><span class="fw-bold">Thể loại:</span> @(book.Category?.CategoryName ?? "N/A")</p>
                    <div class="text-center">
                        <img src="/ImageBooks/@book.ImageUrl" alt="@book.Title" class="img-fluid" style="max-height: 200px; object-fit: contain;">
                    </div>
                </div>
                <div class="card-footer bg-white border-0 text-end pb-3 pe-3 pt-0">
                    <a asp-action="Details" asp-route-id="@book.BookId" class="btn btn-sm btn-outline-secondary px-3">Chi tiết</a>
                    <button class="btn btn-sm btn-success px-3 ms-1">Xóa</button>
                </div>
            </div>
        </div>
    }
</div>