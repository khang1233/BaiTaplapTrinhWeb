@model IEnumerable<BaiTapBuoi6.Models.Product>

@{
    ViewData["Title"] = "Cửa hàng sản phẩm";
    var categories = ViewBag.Categories as IEnumerable<BaiTapBuoi6.Models.Category>;
    int? currentCategoryId = ViewBag.CurrentCategoryId as int?;
}

<div class="container py-4">
    <div class="row">
        <!-- Sidebar Danh mục bên trái -->
        <div class="col-lg-3 mb-4">
            <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-grid-fill me-2"></i>Danh mục sản phẩm</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-action="Index" asp-route-categoryId="" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 @(currentCategoryId == null ? "active fw-bold" : "")">
                        <span>Tất cả sản phẩm</span>
                    </a>
                    @if (categories != null)
                    {
                        foreach (var cat in categories)
                        {
                            <a asp-action="Index" asp-route-categoryId="@cat.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3 @(currentCategoryId == cat.Id ? "active fw-bold" : "")">
                                <span>@cat.Name</span>
                            </a>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Danh sách sản phẩm bên phải -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <div>
                    <h2 class="h3 fw-bold text-dark mb-0">Sản phẩm nổi bật</h2>
                    <p class="text-muted mb-0 small">Duyệt qua các sản phẩm chất lượng cao của cửa hàng</p>
                </div>
            </div>

            <div class="row row-cols-1 row-cols-md-3 g-4">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden product-card transition-all">
                                <div class="position-relative text-center bg-light" style="height: 200px;">
                                    @if (item.Images != null && item.Images.Any())
                                    {
                                        <img src="@item.Images.FirstOrDefault()?.Url" class="card-img-top w-100 h-100" style="object-fit: cover;" alt="@item.Name" />
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center h-100 text-muted fst-italic bg-light">
                                            Không có ảnh
                                        </div>
                                    }
                                    <span class="position-absolute top-0 start-0 m-3 badge bg-primary text-white px-2 py-1 small">
                                        @item.Category?.Name
                                    </span>
                                </div>
                                <div class="card-body d-flex flex-column p-4">
                                    <h5 class="card-title fw-bold text-dark text-truncate mb-2" title="@item.Name">@item.Name</h5>
                                    <p class="card-text text-muted text-truncate-2 small mb-3" style="height: 40px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        @item.Description
                                    </p>
                                    <div class="mt-auto d-flex justify-content-between align-items-center">
                                        <span class="fs-5 fw-bold text-primary">@string.Format("{0:N0}", item.Price) đ</span>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm px-3 rounded-pill fw-semibold">
                                            Chi tiết
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 py-5 text-center text-muted">
                        Chưa có sản phẩm nào thuộc danh mục này.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.08) !important;
    }
    .transition-all {
        transition: all 0.3s ease-in-out;
    }
</style>
