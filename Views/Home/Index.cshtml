@model IEnumerable<BaiTapBuoi6.Models.Product>

@{
    ViewData["Title"] = "QLBanHang - Trang chủ";
}

<!-- Hero section -->
<div class="bg-gradient-hero py-5 mb-5 text-white position-relative overflow-hidden rounded-3 shadow">
    <div class="container my-4 position-relative z-index-2">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h1 class="display-3 fw-bold mb-3 tracking-tight">Chào mừng đến với QLBanHang</h1>
                <p class="lead mb-4 opacity-90">Hệ thống mua sắm trực tuyến hàng đầu với đa dạng các mặt hàng chất lượng cao, phục vụ tận tình 24/7.</p>
                <div class="d-flex gap-3">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-light btn-lg px-4 py-3 rounded-pill fw-bold text-primary shadow-sm">
                        Mua sắm ngay
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-outline-light btn-lg px-4 py-3 rounded-pill fw-bold">
                            Khu vực Quản trị
                        </a>
                    }
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block text-center">
                <div class="hero-icon-container">
                    <i class="bi bi-shop display-1 text-white opacity-75"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Featured products -->
<div class="container mb-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-dark mb-2">Sản phẩm nổi bật</h2>
        <p class="text-muted">Danh sách các sản phẩm mới nhất được cập nhật trên hệ thống</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden product-card transition-all">
                        <div class="position-relative text-center bg-light" style="height: 220px;">
                            @if (item.Images != null && item.Images.Any())
                            {
                                <img src="@item.Images.FirstOrDefault()?.Url" class="card-img-top w-100 h-100" style="object-fit: cover;" alt="@item.Name" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100 text-muted fst-italic bg-light">
                                    Không có ảnh
                                </div>
                            }
                            <span class="position-absolute top-0 start-0 m-3 badge bg-primary text-white px-2 py-1 small">
                                @item.Category?.Name
                            </span>
                        </div>
                        <div class="card-body d-flex flex-column p-4">
                            <h5 class="card-title fw-bold text-dark text-truncate mb-2" title="@item.Name">@item.Name</h5>
                            <p class="card-text text-muted text-truncate-2 small mb-3" style="height: 40px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @item.Description
                            </p>
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <span class="fs-5 fw-bold text-primary">@string.Format("{0:N0}", item.Price) đ</span>
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm px-3 rounded-pill fw-semibold">
                                    Chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 py-5 text-center text-muted">
                Hệ thống đang cập nhật sản phẩm. Vui lòng quay lại sau!
            </div>
        }
    </div>
</div>

<style>
    .bg-gradient-hero {
        background: linear-gradient(135deg, #4f46e5 0%, #06b6d4 100%);
    }
    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.08) !important;
    }
    .transition-all {
        transition: all 0.3s ease-in-out;
    }
    .hero-icon-container {
        font-size: 8rem;
        animation: float 4s ease-in-out infinite;
    }
    @@keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
        100% { transform: translateY(0px); }
    }
</style>
