@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập hệ thống";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">
            <div class="card border-0 shadow rounded-3 overflow-hidden">
                <div class="card-header bg-primary text-white py-3 text-center">
                    <h2 class="h4 mb-0 fw-bold">Đăng nhập</h2>
                    <p class="mb-0 opacity-80 small">Sử dụng tài khoản thành viên của bạn</p>
                </div>
                <div class="card-body p-4">
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                        
                        <!-- UserNameOrEmail -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.UserNameOrEmail" class="form-control" autocomplete="username" aria-required="true" placeholder="username" />
                            <label asp-for="Input.UserNameOrEmail">Tên đăng nhập hoặc Email</label>
                            <span asp-validation-for="Input.UserNameOrEmail" class="text-danger small"></span>
                        </div>

                        <!-- Password -->
                        <div class="form-floating mb-4">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password">Mật khẩu</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <!-- RememberMe -->
                        <div class="form-check mb-4">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label class="form-check-label text-muted small" asp-for="Input.RememberMe">
                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                            </label>
                        </div>

                        <button id="login-submit" type="submit" class="w-100 btn btn-primary btn-lg rounded-pill fw-bold py-2 shadow-sm mb-3">
                            Đăng nhập
                        </button>
                        
                        <div class="text-center d-flex justify-content-between align-items-center">
                            <a id="forgot-password" asp-page="./ForgotPassword" class="small text-decoration-none">Quên mật khẩu?</a>
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="small fw-semibold text-decoration-none text-primary">Đăng ký mới</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
