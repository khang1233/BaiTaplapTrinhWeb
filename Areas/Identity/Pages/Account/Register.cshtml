@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký thành viên";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-9 col-lg-7">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <!-- Premium Green/Blue Gradient Header -->
                <div class="card-header card-header-gradient-primary text-white py-4 text-center" 
                     style="background: linear-gradient(135deg, #10b981 0%, #3b82f6 100%);">
                    <h2 class="h3 mb-1 fw-extrabold tracking-tight">Tạo tài khoản mới</h2>
                    <p class="mb-0 opacity-75 small">Đăng ký thành viên Bookstore Premium ngay hôm nay</p>
                </div>
                <div class="card-body p-5 bg-white">
                    <form asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <!-- Validation summary -->
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm mb-4 small" role="alert"></div>

                        <div class="row">
                            <!-- UserName -->
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.UserName" class="form-control" autocomplete="username" aria-required="true" placeholder="username" />
                                    <label asp-for="Input.UserName"><i class="bi bi-person-fill me-1"></i> Tên đăng nhập</label>
                                    <span asp-validation-for="Input.UserName" class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- Email -->
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.Email" class="form-control" autocomplete="email" aria-required="true" placeholder="name@example.com" />
                                    <label asp-for="Input.Email"><i class="bi bi-envelope-fill me-1"></i> Email</label>
                                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- FullName -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.FullName" class="form-control" placeholder="Họ và tên" />
                            <label asp-for="Input.FullName"><i class="bi bi-card-text me-1"></i> Họ và tên</label>
                            <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                        </div>

                        <!-- Address -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Address" class="form-control" placeholder="Địa chỉ" />
                            <label asp-for="Input.Address"><i class="bi bi-geo-alt-fill me-1"></i> Địa chỉ giao hàng</label>
                            <span asp-validation-for="Input.Address" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <!-- Password -->
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                                    <label asp-for="Input.Password"><i class="bi bi-key-fill me-1"></i> Mật khẩu</label>
                                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- ConfirmPassword -->
                            <div class="col-md-6 mb-4">
                                <div class="form-floating">
                                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                                    <label asp-for="Input.ConfirmPassword"><i class="bi bi-key-fill me-1"></i> Xác nhận mật khẩu</label>
                                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Premium Button -->
                        <button id="registerSubmit" type="submit" 
                                class="w-100 btn btn-premium-pill py-3 fs-6 shadow-sm mb-4 text-white" 
                                style="background: linear-gradient(135deg, #10b981 0%, #3b82f6 100%); border: none;">
                            Hoàn tất Đăng ký <i class="bi bi-check-circle-fill ms-1"></i>
                        </button>
                        
                        <div class="text-center border-top pt-4">
                            <span class="text-muted small">Đã có tài khoản? </span>
                            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="small fw-bold text-decoration-none text-success">Đăng nhập ngay</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
