@model BaiTapBuoi6.Models.Category

@{
    ViewData["Title"] = "Chi tiết danh mục - Admin";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-info py-3 text-white">
                    <h2 class="h4 mb-0 fw-bold">Chi tiết danh mục (Admin)</h2>
                </div>
                <div class="card-body p-4">
                    <dl class="row">
                        <dt class="col-sm-4 fw-semibold text-muted">Mã danh mục:</dt>
                        <dd class="col-sm-8 text-dark fw-bold fs-5">@Html.DisplayFor(model => model.Id)</dd>

                        <dt class="col-sm-4 fw-semibold text-muted">Tên danh mục:</dt>
                        <dd class="col-sm-8 text-dark fw-bold fs-5">@Html.DisplayFor(model => model.Name)</dd>
                    </dl>

                    <hr class="my-4" />

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-medium">Quay lại</a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4 text-dark fw-semibold">Chỉnh sửa</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
