@model BaiTapBuoi6.Models.Category

@{
    ViewData["Title"] = "Thêm danh mục mới - Admin";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-danger text-white py-3">
                    <h2 class="h4 mb-0 fw-bold">Thêm danh mục mới (Admin)</h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-4">
                            <label asp-for="Name" class="form-label fw-semibold">Tên danh mục</label>
                            <input asp-for="Name" class="form-control" placeholder="Nhập tên chủ đề/danh mục..." />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-medium">Quay lại</a>
                            <input type="submit" value="Create" class="btn btn-danger px-4 fw-semibold" />
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
