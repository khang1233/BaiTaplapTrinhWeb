@model IEnumerable<BaiTapBuoi6.Models.Category>

@{
    ViewData["Title"] = "Quản lý Danh mục - Admin";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h1 class="h2 text-danger fw-bold mb-1"><span class="badge bg-danger me-2">Admin</span>Quản lý Danh mục</h1>
            <p class="text-muted mb-0">Xem danh sách, thêm mới, chỉnh sửa, và xóa danh mục sản phẩm</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-dark px-4 py-2 shadow-sm fw-semibold">
                Quản lý sản phẩm
            </a>
            <a asp-action="Create" class="btn btn-danger px-4 py-2 shadow-sm fw-semibold">
                Thêm danh mục mới
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Mã danh mục</th>
                            <th>Tên danh mục</th>
                            <th class="text-center pe-4" style="width: 240px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold ps-4 text-muted">@Html.DisplayFor(modelItem => item.Id)</td>
                                    <td class="fw-bold text-dark fs-5">@Html.DisplayFor(modelItem => item.Name)</td>
                                    <td class="text-center pe-4">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning px-3 text-dark fw-medium">
                                                Sửa
                                            </a>
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info px-3 text-white fw-medium">
                                                Chi tiết
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger px-3 fw-medium">
                                                Xóa
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center py-5 text-muted">
                                    Chưa có danh mục nào trong hệ thống.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
